{
  "name": "Bubu Dudu GIF Picker Extension",
  "description": "Bubu Dudu GIF Picker Extension is a simple and cute extension that lets you select your favorite GIFs with just one click.",
  "version": "1.0.1",
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "32": "images/icon32.png",
      "48": "images/icon48.png",
      "128": "images/bubu-dudu.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "48": "images/icon48.png",
    "128": "images/bubu-dudu.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "js/content.js",
        "js/constants.js",
        "js/utils.js"
      ],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "host_permissions": [
    "*://*/*"
  ],
  "permissions": [
    "webNavigation",
    "storage"
  ],
  "manifest_version": 3
}